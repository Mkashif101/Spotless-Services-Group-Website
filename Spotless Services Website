  .stmt-title{font-size:clamp(36px,9vw,60px);}
  #statement{padding:80px 20px;}
  .ft{grid-template-columns:1fr;gap:28px;}
  .f-grid{grid-template-columns:1fr;}
  .scroll-cue{display:none;}
}
</style>
