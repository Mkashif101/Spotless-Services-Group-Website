<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SSG — Spotless Services Group | Sydney Security</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
:root{
  --navy:#0B1D45;
  --orange:#F47920;
  --orange2:#FF9B3D;
  --sky:#3AA3DC;
  --white:#FFFFFF;
  --snow:#F7F8FB;
  --mist:#EEF1F7;
  --ink:#1A2B4A;
  --ash:#7A8AA0;
  --rule:#E2E7F0;
}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--ink);overflow-x:hidden;}

/* ─── CURSOR ─────────────────────────────── */
#cur,#cur-ring{position:fixed;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);border-radius:50%;display:none;}
#cur{width:10px;height:10px;background:var(--orange);transition:width .18s,height .18s;}
#cur-ring{z-index:9998;width:34px;height:34px;border:1.5px solid rgba(244,121,32,.45);}

/* ─── NAV ────────────────────────────────── */
#nav{position:fixed;inset:0 0 auto;z-index:800;height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 56px;transition:background .4s,border-color .4s;border-bottom:1px solid transparent;}
#nav.scrolled{background:rgba(6,18,46,.97);backdrop-filter:blur(16px);border-color:rgba(255,255,255,.06);}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-name{font-family:'DM Serif Display',serif;font-size:21px;color:var(--white);letter-spacing:.3px;}
.logo-name em{color:var(--orange);font-style:normal;}
#nav ul{list-style:none;display:flex;align-items:center;gap:36px;}
#nav ul a{color:rgba(255,255,255,.6);text-decoration:none;font-size:12px;font-weight:500;letter-spacing:.7px;text-transform:uppercase;transition:color .2s;}
#nav ul a:hover{color:var(--white);}
.nav-btn{background:var(--orange)!important;color:var(--white)!important;padding:9px 22px;border-radius:3px;font-weight:600!important;}
.nav-btn:hover{background:var(--orange2)!important;}
.ham{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;}
.ham span{display:block;width:22px;height:2px;background:var(--white);transition:all .3s;}

/* ─── MOB MENU ───────────────────────────── */
#mob{position:fixed;inset:72px 0 0;background:rgba(5,14,36,.97);backdrop-filter:blur(18px);z-index:700;display:none;flex-direction:column;align-items:center;justify-content:center;gap:36px;}
#mob.open{display:flex;}
#mob a{color:rgba(255,255,255,.7);font-size:22px;font-weight:500;text-decoration:none;letter-spacing:.5px;text-transform:uppercase;transition:color .2s;}
#mob a:hover{color:var(--orange);}
#mob .mob-cta{background:var(--orange);color:var(--white)!important;padding:14px 32px;border-radius:3px;}

/* ─── HERO — CARTER CARTER STYLE ─────────── */
#hero{position:relative;height:100vh;overflow:hidden;display:flex;align-items:flex-end;}

/* Cycling background slides */
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 1.4s ease;will-change:opacity;}
.hero-bg.active{opacity:1;}
.hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(5,14,36,.88) 0%,rgba(5,14,36,.6) 55%,rgba(5,14,36,.35) 100%);}

/* Grid overlay — subtle texture */
.hero-grid{position:absolute;inset:0;z-index:2;pointer-events:none;
  background:linear-gradient(rgba(58,163,220,.03) 1px,transparent 1px),
             linear-gradient(90deg,rgba(58,163,220,.03) 1px,transparent 1px);
  background-size:80px 80px;}

/* Hero content */
.hero-content{position:relative;z-index:3;padding:0 56px 80px;width:100%;}

/* Stacked slide text — Carter Carter large cinematic style */
.hero-slides{position:relative;height:auto;}
.hslide{position:absolute;left:0;bottom:0;opacity:0;transform:translateY(40px);transition:opacity .9s ease,transform .9s ease;pointer-events:none;}
.hslide.active{position:relative;opacity:1;transform:translateY(0);pointer-events:auto;}
.hslide.exit{position:absolute;opacity:0;transform:translateY(-30px);}

.h-pre{font-size:13px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--orange);display:flex;align-items:center;gap:10px;margin-bottom:20px;}
.h-pre::before{content:'';display:inline-block;width:28px;height:1.5px;background:var(--orange);}

.h-title{font-family:'DM Serif Display',serif;font-size:clamp(58px,8vw,116px);color:var(--white);line-height:.96;letter-spacing:-2px;margin-bottom:28px;}
.h-title em{color:var(--orange);font-style:normal;}
.h-title .sky{color:var(--sky);}
.h-title .ghost{-webkit-text-stroke:1.5px rgba(255,255,255,.25);color:transparent;}

.h-sub{font-size:16px;color:rgba(255,255,255,.5);line-height:1.7;max-width:400px;margin-bottom:36px;}
.h-btns{display:flex;gap:14px;flex-wrap:wrap;}

/* Hero bottom bar */
.hero-bar{position:absolute;bottom:0;left:0;right:0;z-index:3;display:flex;align-items:stretch;border-top:1px solid rgba(255,255,255,.08);}
.hbar-stat{flex:1;padding:20px 28px;border-right:1px solid rgba(255,255,255,.08);display:flex;flex-direction:column;gap:4px;}
.hbar-stat:last-child{border-right:none;}
.hbar-val{font-family:'DM Serif Display',serif;font-size:28px;color:var(--white);line-height:1;}
.hbar-val span{color:var(--orange);font-size:20px;}
.hbar-lbl{font-size:11px;color:rgba(255,255,255,.38);letter-spacing:1.5px;text-transform:uppercase;}
.hbar-dot{width:6px;height:6px;border-radius:50%;background:#22c55e;display:inline-block;margin-right:6px;animation:pulse 1.8s infinite;}

/* Slide indicator dots */
.hero-dots{position:absolute;right:56px;top:50%;transform:translateY(-50%);z-index:3;display:flex;flex-direction:column;gap:10px;}
.hdot{width:3px;height:28px;background:rgba(255,255,255,.2);border-radius:2px;cursor:pointer;transition:background .3s,height .3s;}
.hdot.active{background:var(--orange);height:44px;}

/* Scroll cue */
.scroll-cue{position:absolute;bottom:92px;right:56px;z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:.5;}
.scroll-cue span{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--white);writing-mode:vertical-rl;}
.scroll-line{width:1px;height:48px;background:rgba(255,255,255,.3);position:relative;overflow:hidden;}
.scroll-line::after{content:'';position:absolute;top:-100%;left:0;width:100%;height:100%;background:var(--orange);animation:scrollLine 1.8s ease infinite;}
@keyframes scrollLine{0%{top:-100%}100%{top:100%}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* ─── SHARED HELPERS ─────────────────────── */
.btn-fill{display:inline-flex;align-items:center;gap:9px;background:var(--orange);color:var(--white);padding:14px 30px;border-radius:3px;font-size:14px;font-weight:600;text-decoration:none;transition:background .2s,transform .2s,box-shadow .2s;}
.btn-fill:hover{background:var(--orange2);transform:translateY(-2px);box-shadow:0 10px 28px rgba(244,121,32,.35);}
.btn-ghost{display:inline-flex;align-items:center;gap:9px;background:transparent;color:rgba(255,255,255,.65);padding:14px 30px;border-radius:3px;font-size:14px;font-weight:500;text-decoration:none;border:1px solid rgba(255,255,255,.2);transition:all .2s;}
.btn-ghost:hover{color:var(--white);border-color:rgba(255,255,255,.5);transform:translateY(-2px);}
.eyebrow{font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--orange);margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.eyebrow::before{content:'';display:inline-block;width:24px;height:1.5px;background:var(--orange);}
.h2{font-family:'DM Serif Display',serif;font-size:clamp(32px,3.5vw,50px);color:var(--navy);line-height:1.1;letter-spacing:-.3px;}
.h2 em{color:var(--orange);font-style:normal;}
.h2w{color:var(--white)!important;}
.lead{font-size:15px;color:var(--ash);line-height:1.75;max-width:480px;margin-top:14px;}

/* Scroll reveal */
.sr{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
.sr.in{opacity:1;transform:translateY(0);}
.sl{opacity:0;transform:translateX(-32px);transition:opacity .7s ease,transform .7s ease;}
.sl.in{opacity:1;transform:translateX(0);}
.sr2{opacity:0;transform:translateX(32px);transition:opacity .7s ease,transform .7s ease;}
.sr2.in{opacity:1;transform:translateX(0);}

/* ─── MARQUEE ────────────────────────────── */
.mq{background:var(--orange);padding:13px 0;overflow:hidden;}
.mq-t{display:flex;animation:mqroll 28s linear infinite;white-space:nowrap;}
.mq-i{display:inline-flex;align-items:center;font-size:11px;font-weight:600;color:rgba(255,255,255,.9);letter-spacing:2px;text-transform:uppercase;padding:0 28px;}
.mq-sep{color:rgba(255,255,255,.3);font-size:8px;margin-left:28px;}
@keyframes mqroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─── NUMBERS ────────────────────────────── */
#numbers{background:var(--snow);padding:60px 56px;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);}
.num-g{display:grid;grid-template-columns:repeat(4,1fr);}
.num-i{padding:0 36px;border-right:1px solid var(--rule);}
.num-i:first-child{padding-left:0;}
.num-i:last-child{border-right:none;}
.num-v{font-family:'DM Serif Display',serif;font-size:50px;color:var(--navy);line-height:1;margin-bottom:4px;}
.num-v span{color:var(--orange);}
.num-l{font-size:13px;color:var(--ash);}

/* ─── STATEMENT SECTION (Carter Carter inspired) ─── */
#statement{background:var(--navy);padding:120px 56px;position:relative;overflow:hidden;}
#statement::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,#06122E 0%,#0B1D45 45%,#0E2657 75%,#091A3A 100%);}
.stmt-inner{position:relative;z-index:2;max-width:1100px;}
.stmt-pre{font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:32px;}
.stmt-title{font-family:'DM Serif Display',serif;font-size:clamp(42px,5.5vw,80px);color:var(--white);line-height:1.05;letter-spacing:-1px;}
.stmt-title em{color:var(--orange);font-style:normal;}
.stmt-title .ghost{-webkit-text-stroke:1.5px rgba(255,255,255,.2);color:transparent;}
.stmt-title .sky{color:var(--sky);}
.stmt-row{display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-top:72px;align-items:start;}
.stmt-left p{font-size:16px;color:rgba(255,255,255,.5);line-height:1.8;margin-bottom:28px;}
.stmt-right{}
.stmt-pillars{display:flex;flex-direction:column;}
.s-pil{display:flex;align-items:flex-start;gap:16px;padding:20px 0;border-bottom:1px solid rgba(255,255,255,.07);}
.s-pil:first-child{border-top:1px solid rgba(255,255,255,.07);}
.s-pil-n{font-family:'DM Serif Display',serif;font-size:13px;color:var(--orange);opacity:.55;min-width:24px;margin-top:2px;}
.s-pil-body strong{display:block;font-size:14px;font-weight:600;color:var(--white);margin-bottom:3px;}
.s-pil-body span{font-size:13px;color:rgba(255,255,255,.4);line-height:1.6;}

/* ─── ABOUT ──────────────────────────────── */
#about{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:580px;}
.a-img{position:relative;overflow:hidden;min-height:500px;}
.a-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 7s ease;}
.a-img:hover img{transform:scale(1.04);}
.a-img-ov{position:absolute;inset:0;background:linear-gradient(135deg,rgba(11,29,69,.35) 0%,transparent 65%);}
.a-txt{padding:80px 68px;display:flex;flex-direction:column;justify-content:center;background:var(--white);}
.a-pillars{margin-top:36px;}
.a-pil{display:flex;align-items:flex-start;gap:16px;padding:18px 0;border-bottom:1px solid var(--rule);transition:all .2s;cursor:default;}
.a-pil:first-child{border-top:1px solid var(--rule);}
.a-ico{width:36px;height:36px;flex-shrink:0;background:var(--mist);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;transition:background .2s;}
.a-pil:hover .a-ico{background:rgba(244,121,32,.12);}
.a-pil strong{display:block;font-size:14px;font-weight:600;color:var(--navy);margin-bottom:2px;}
.a-pil span{font-size:13px;color:var(--ash);line-height:1.6;}

/* ─── SERVICES ───────────────────────────── */
#services{background:linear-gradient(160deg,#06122E 0%,#0B1D45 40%,#112560 70%,#07152E 100%);padding:108px 0;overflow:hidden;}
.svc-hdr{padding:0 56px;display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;}
.svc-track{display:flex;gap:18px;padding:0 56px 28px;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;cursor:grab;}
.svc-track::-webkit-scrollbar{display:none;}
.svc-track:active{cursor:grabbing;}
.svc-card{flex-shrink:0;width:288px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:32px 28px;scroll-snap-align:start;transition:background .3s,border-color .3s,transform .3s;}
.svc-card:hover{background:rgba(255,255,255,.08);border-color:rgba(244,121,32,.35);transform:translateY(-5px);}
.svc-n{font-family:'DM Serif Display',serif;font-size:12px;color:var(--orange);opacity:.6;margin-bottom:16px;display:block;}
.svc-ico{font-size:26px;margin-bottom:12px;display:block;}
.svc-card h3{font-family:'DM Serif Display',serif;font-size:18px;color:var(--white);margin-bottom:10px;line-height:1.25;}
.svc-card p{font-size:13px;color:rgba(255,255,255,.42);line-height:1.7;}
.svc-line{height:1px;background:rgba(255,255,255,.07);margin:16px 0;transform:scaleX(0);transform-origin:left;transition:transform .4s;}
.svc-card:hover .svc-line{transform:scaleX(1);}
.svc-more{font-size:12px;font-weight:600;color:var(--orange);opacity:0;transform:translateX(-8px);transition:opacity .3s,transform .3s;display:flex;align-items:center;gap:6px;}
.svc-card:hover .svc-more{opacity:1;transform:translateX(0);}
.svc-arrows{display:flex;gap:8px;}
.svc-arrows button{width:34px;height:34px;border:1px solid rgba(255,255,255,.12);background:transparent;border-radius:4px;color:rgba(255,255,255,.4);font-size:14px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;}
.svc-arrows button:hover{background:rgba(255,255,255,.08);color:var(--white);border-color:rgba(255,255,255,.3);}

/* ─── SHOWCASE 3D SCROLL ─────────────────── */
#showcase{background:linear-gradient(175deg,#0E2254 0%,#091A3A 50%,#06122E 100%);}
.sc-outer{height:2200px;position:relative;}
.sc-sticky{position:sticky;top:0;height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;perspective:1200px;overflow:hidden;padding:60px 56px;}
.sc-head{text-align:center;margin-bottom:44px;}
.sc-head h2{font-family:'DM Serif Display',serif;font-size:clamp(28px,4vw,50px);color:var(--white);line-height:1.1;}
.sc-head h2 em{color:var(--orange);font-style:normal;}
.sc-head p{font-size:14px;color:rgba(255,255,255,.35);margin-top:10px;}
.sc-card{width:min(960px,90vw);height:min(490px,55vh);border-radius:20px;background:linear-gradient(140deg,#0B1D45,#091530,#0A1A40);border:1px solid rgba(255,255,255,.08);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.4),0 60px 100px rgba(0,0,0,.25);will-change:transform;display:grid;grid-template-columns:1fr 1fr;opacity:0;transform:rotateX(22deg) scale(.84) translateY(60px);}
.sc-l{padding:44px 40px;display:flex;flex-direction:column;justify-content:space-between;border-right:1px solid rgba(255,255,255,.06);}
.sc-tag{display:inline-block;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--orange);border:1px solid rgba(244,121,32,.3);padding:4px 10px;border-radius:2px;margin-bottom:18px;}
.sc-l h3{font-family:'DM Serif Display',serif;font-size:30px;color:var(--white);line-height:1.2;margin-bottom:12px;}
.sc-l h3 em{color:var(--sky);font-style:normal;}
.sc-l p{font-size:13px;color:rgba(255,255,255,.4);line-height:1.7;}
.sc-metrics{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.sc-m{background:rgba(255,255,255,.04);border-radius:8px;padding:14px;}
.sc-mv{font-family:'DM Serif Display',serif;font-size:22px;color:var(--white);line-height:1;margin-bottom:3px;}
.sc-mv em{font-style:normal;font-size:14px;color:var(--orange);}
.sc-ml{font-size:11px;color:rgba(255,255,255,.3);letter-spacing:.5px;}
.sc-r{background:linear-gradient(145deg,#0A1E4A,#091530,#07122A);display:flex;align-items:center;justify-content:center;padding:44px;position:relative;overflow:hidden;}
.sc-glow{position:absolute;top:-40%;right:-30%;width:260px;height:260px;background:radial-gradient(circle,rgba(58,163,220,.13),transparent 65%);}
.sc-shield{position:relative;z-index:2;filter:drop-shadow(0 0 40px rgba(58,163,220,.3));}

/* ─── SECTORS ────────────────────────────── */
#sectors{background:var(--snow);padding:108px 56px;}
.sec-layout{display:grid;grid-template-columns:200px 1fr;gap:64px;margin-top:52px;align-items:start;}
.sec-nav{display:flex;flex-direction:column;position:sticky;top:88px;}
.s-tab{display:flex;align-items:center;gap:12px;padding:15px 0;border-bottom:1px solid var(--rule);cursor:pointer;transition:all .2s;}
.s-tab:first-child{border-top:1px solid var(--rule);}
.s-ico{width:32px;height:32px;background:var(--mist);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;transition:background .2s;flex-shrink:0;}
.s-name{font-size:13px;font-weight:500;color:var(--ash);transition:color .2s;}
.s-arr{margin-left:auto;color:var(--rule);transition:all .2s;font-size:13px;}
.s-tab.active .s-ico{background:rgba(244,121,32,.12);}
.s-tab.active .s-name{color:var(--navy);font-weight:600;}
.s-tab.active .s-arr{color:var(--orange);transform:translateX(3px);}
.s-panel{display:none;animation:slideIn .35s ease;}
.s-panel.active{display:block;}
@keyframes slideIn{from{opacity:0;transform:translateX(18px)}to{opacity:1;transform:translateX(0)}}
.s-img{width:100%;height:290px;border-radius:12px;overflow:hidden;margin-bottom:26px;}
.s-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s;}
.s-img:hover img{transform:scale(1.03);}
.s-panel h3{font-family:'DM Serif Display',serif;font-size:26px;color:var(--navy);margin-bottom:10px;}
.s-panel p{font-size:14px;color:var(--ash);line-height:1.75;margin-bottom:20px;}
.s-tags{display:flex;flex-wrap:wrap;gap:8px;}
.s-tag{font-size:12px;font-weight:500;color:var(--navy);background:var(--mist);border-radius:100px;padding:5px 14px;}

/* ─── TESTIMONIALS ───────────────────────── */
#testimonials{background:var(--white);padding:108px 0;overflow:hidden;border-top:1px solid var(--rule);}
.t-hdr{padding:0 56px;text-align:center;margin-bottom:60px;}
.t-hdr .lead{margin:0 auto;}
.t-wrap{position:relative;overflow:hidden;}
.t-wrap::before,.t-wrap::after{content:'';position:absolute;top:0;bottom:0;width:160px;z-index:2;pointer-events:none;}
.t-wrap::before{left:0;background:linear-gradient(to right,var(--white),transparent);}
.t-wrap::after{right:0;background:linear-gradient(to left,var(--white),transparent);}
.t-track{display:flex;gap:20px;padding:8px 56px 24px;animation:troll 50s linear infinite;width:max-content;}
.t-track:hover{animation-play-state:paused;}
@keyframes troll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.t-card{flex-shrink:0;width:310px;background:var(--snow);border:1px solid var(--rule);border-radius:14px;padding:26px;transition:box-shadow .3s,border-color .3s,transform .3s;}
.t-card:hover{box-shadow:0 12px 40px rgba(13,31,78,.09);border-color:rgba(244,121,32,.25);transform:translateY(-3px);}
.t-auth{display:flex;align-items:center;gap:11px;margin-bottom:16px;}
.t-av{width:42px;height:42px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid var(--rule);}
.t-av img{width:100%;height:100%;object-fit:cover;display:block;}
.t-name{font-size:14px;font-weight:600;color:var(--navy);line-height:1.2;}
.t-role{font-size:12px;color:var(--ash);margin-top:1px;}
.t-stars{color:var(--orange);font-size:13px;letter-spacing:1px;margin-bottom:10px;}
.t-q{font-size:28px;color:var(--orange);opacity:.2;font-family:'DM Serif Display',serif;line-height:1;margin-bottom:2px;}
.t-txt{font-size:13px;color:var(--ash);line-height:1.7;}

/* ─── CTA ────────────────────────────────── */
#cta{background:linear-gradient(135deg,#0B1D45,#091530,#0E2254,#06122E);padding:96px 56px;text-align:center;position:relative;overflow:hidden;}
#cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 55% 60% at 18% 50%,rgba(244,121,32,.08),transparent 70%),radial-gradient(ellipse 50% 70% at 82% 50%,rgba(58,163,220,.09),transparent 70%);}
#cta>*{position:relative;z-index:2;}
#cta h2{font-family:'DM Serif Display',serif;font-size:clamp(32px,4vw,58px);color:var(--white);line-height:1.08;max-width:600px;margin:0 auto 14px;}
#cta h2 em{color:var(--orange);font-style:normal;}
#cta>p{font-size:15px;color:rgba(255,255,255,.4);margin-bottom:40px;}
.cta-btns{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;}
.cta-tel{font-family:'DM Serif Display',serif;font-size:19px;color:var(--white);text-decoration:none;display:flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.16);padding:12px 22px;border-radius:3px;transition:all .2s;}
.cta-tel:hover{border-color:rgba(255,255,255,.45);}

/* ─── CERTIFICATIONS ─────────────────────── */
#certifications{background:var(--white);padding:108px 56px;}
.cert-layout{display:grid;grid-template-columns:1fr 1fr;gap:72px;margin-top:52px;align-items:start;}
.cert-list{display:flex;flex-direction:column;}
.cert-item{display:flex;align-items:flex-start;gap:16px;padding:24px 0;border-bottom:1px solid var(--rule);transition:all .25s;cursor:default;}
.cert-item:first-child{border-top:1px solid var(--rule);}
.cert-n{font-family:'DM Serif Display',serif;font-size:13px;color:var(--orange);opacity:.55;min-width:20px;margin-top:2px;}
.cert-body strong{display:block;font-size:14px;font-weight:600;color:var(--navy);margin-bottom:4px;}
.cert-body span{font-size:13px;color:var(--ash);line-height:1.6;}
.cert-item:hover .cert-body strong{color:var(--orange);}
.cert-vis{position:sticky;top:88px;}
.cert-card{background:linear-gradient(135deg,#0B1D45,#0E2254,#091A3A);border-radius:16px;padding:40px 36px;color:var(--white);}
.cert-card .eyebrow{color:var(--sky);}
.cert-card .eyebrow::before{background:var(--sky);}
.cert-card h3{font-family:'DM Serif Display',serif;font-size:26px;margin:0 0 10px;}
.cert-card p{font-size:13px;color:rgba(255,255,255,.4);line-height:1.7;margin-bottom:26px;}
.cert-badges{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.cbadge{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:14px;text-align:center;}
.cbadge-ico{font-size:20px;margin-bottom:5px;}
.cbadge-name{font-size:11px;color:rgba(255,255,255,.45);letter-spacing:.5px;}

/* ─── CONTACT ────────────────────────────── */
#contact{background:var(--snow);padding:108px 56px;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start;}
.con-l h2{font-family:'DM Serif Display',serif;font-size:40px;color:var(--navy);line-height:1.1;margin-bottom:12px;}
.con-l h2 em{color:var(--orange);font-style:normal;}
.con-l>p{font-size:15px;color:var(--ash);line-height:1.75;margin-bottom:36px;}
.c-list{display:flex;flex-direction:column;gap:16px;}
.c-item{display:flex;align-items:flex-start;gap:13px;}
.c-ico{width:36px;height:36px;background:rgba(244,121,32,.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.c-body strong{display:block;font-size:13px;font-weight:600;color:var(--navy);margin-bottom:2px;}
.c-body span{font-size:13px;color:var(--ash);}
.con-form{background:var(--white);border-radius:14px;padding:36px;border:1px solid var(--rule);}
.f-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.fg{display:flex;flex-direction:column;gap:5px;}
.fg.full{grid-column:1/-1;}
.fg label{font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--ash);}
.fg input,.fg select,.fg textarea{padding:11px 13px;border:1.5px solid var(--rule);border-radius:6px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--navy);background:var(--snow);outline:none;transition:border-color .2s,background .2s;width:100%;appearance:none;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--orange);background:var(--white);}
.fg textarea{resize:vertical;min-height:100px;}
.btn-sub{width:100%;background:var(--navy);color:var(--white);padding:14px 24px;border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .25s;margin-top:4px;}
.btn-sub:hover{background:var(--orange);transform:translateY(-1px);box-shadow:0 8px 24px rgba(244,121,32,.3);}
.con-f-wrap{display:flex;flex-direction:column;gap:13px;}

/* ─── RECON ──────────────────────────────── */
#recon{background:linear-gradient(135deg,#06122E,#0B1D45,#091A3A);padding:48px 56px;border-top:1px solid rgba(255,255,255,.05);}
.recon-in{max-width:760px;margin:0 auto;display:flex;align-items:center;gap:28px;}
.r-flags{display:flex;gap:8px;flex-shrink:0;}
.rflag{width:40px;height:40px;border-radius:50%;overflow:hidden;border:1.5px solid rgba(255,255,255,.15);}
.rflag img{width:100%;height:100%;object-fit:cover;display:block;}
.r-txt h5{font-size:13px;font-weight:600;color:rgba(255,255,255,.65);margin-bottom:4px;}
.r-txt p{font-size:12px;color:rgba(255,255,255,.3);line-height:1.65;}

/* ─── FOOTER ─────────────────────────────── */
footer{background:linear-gradient(160deg,#040D20,#060F28,#050E24);padding:56px 56px 28px;}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr;gap:52px;padding-bottom:40px;border-bottom:1px solid rgba(255,255,255,.06);margin-bottom:24px;}
.fb .fn{font-family:'DM Serif Display',serif;font-size:20px;color:var(--white);}
.fb .fn em{color:var(--orange);font-style:normal;}
.fb>p{font-size:13px;color:rgba(255,255,255,.28);line-height:1.7;margin-top:10px;max-width:260px;}
.fc h5{font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:14px;}
.fc ul{list-style:none;display:flex;flex-direction:column;gap:9px;}
.fc ul a{color:rgba(255,255,255,.38);font-size:13px;text-decoration:none;transition:color .2s;}
.fc ul a:hover{color:var(--orange);}
.fb-bot{display:flex;justify-content:space-between;align-items:center;}
.fb-bot p,.fb-bot span{font-size:12px;color:rgba(255,255,255,.18);}

/* ─── RESPONSIVE ─────────────────────────── */
@media(max-width:1100px){
  .stmt-row{grid-template-columns:1fr;}
  #about{grid-template-columns:1fr;} .a-img{min-height:300px;}
  .sec-layout{grid-template-columns:1fr;} .sec-nav{position:static;}
  .cert-layout{grid-template-columns:1fr;} .cert-vis{position:static;}
  #contact{grid-template-columns:1fr;}
  .ft{grid-template-columns:1fr 1fr;} .fb{grid-column:1/-1;}
  .num-g{grid-template-columns:1fr 1fr;gap:28px;} .num-i{border-right:none;padding:0;}
  .hero-bar{display:none;}
  .hero-dots{right:20px;}
}
@media(max-width:768px){
  #nav{padding:0 20px;}
  #nav ul{display:none;}
  .ham{display:flex;}
  .hero-content{padding:0 20px 60px;}
  .h-title{font-size:clamp(42px,12vw,72px);}
  #numbers{padding:48px 20px;}
  .a-txt{padding:48px 24px;}
  #services,.svc-hdr,.svc-track{padding-left:20px;padding-right:20px;}
