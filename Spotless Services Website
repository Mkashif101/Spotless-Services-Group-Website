<script>
(function(){
'use strict';

/* ── CURSOR ──────────────────────────────────── */
var cur=document.getElementById('cur'),ring=document.getElementById('cur-ring');
var mx=0,my=0,rx=0,ry=0;
if(window.matchMedia('(pointer:fine)').matches){
  cur.style.display='block'; ring.style.display='block';
  document.body.style.cursor='none';
  document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
  (function tick(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(tick);})();
}

/* ── HERO BACKGROUND + SLIDE CYCLE ──────────── */
var bgs=[document.getElementById('bg0'),document.getElementById('bg1'),document.getElementById('bg2'),document.getElementById('bg3')];
var slides=[document.getElementById('hs0'),document.getElementById('hs1'),document.getElementById('hs2'),document.getElementById('hs3')];
var dots=document.querySelectorAll('.hdot');
var current=0;
var TOTAL=bgs.length;

function goTo(idx){
  // backgrounds
  bgs[current].classList.remove('active');
  slides[current].classList.remove('active');
  slides[current].classList.add('exit');
  var prev=current;
  current=idx;
  bgs[current].classList.add('active');
  // small delay so exit animation plays
  setTimeout(function(){slides[prev].classList.remove('exit');},900);
  slides[current].classList.add('active');
  // dots
  dots.forEach(function(d,i){d.classList.toggle('active',i===current);});
}

// auto-advance every 6s
var heroTimer=setInterval(function(){goTo((current+1)%TOTAL);},6000);

// dot click
dots.forEach(function(d){
  d.addEventListener('click',function(){
    clearInterval(heroTimer);
    goTo(parseInt(d.dataset.i));
    heroTimer=setInterval(function(){goTo((current+1)%TOTAL);},6000);
  });
});

// Ken Burns zoom on active bg
function applyKenBurns(){
  bgs.forEach(function(bg,i){
    bg.style.transform=i===current?'scale(1.06)':'scale(1)';
    bg.style.transition=i===current?'transform 7s ease':'transform 1.4s ease';
  });
}
applyKenBurns();
bgs.forEach(function(bg,i){
  bg.addEventListener('transitionend',function(e){if(e.propertyName==='opacity'&&bg.classList.contains('active'))applyKenBurns();});
});

/* ── NAV SCROLL ──────────────────────────────── */
window.addEventListener('scroll',onScroll,{passive:true});
function onScroll(){
  document.getElementById('nav').classList.toggle('scrolled',window.scrollY>60);
  update3D();
}

/* ── MOBILE MENU ─────────────────────────────── */
var hamBtn=document.getElementById('ham'),mob=document.getElementById('mob');
hamBtn.addEventListener('click',function(){
  var open=mob.classList.toggle('open');
  var s=hamBtn.querySelectorAll('span');
  if(open){s[0].style.transform='translateY(7px) rotate(45deg)';s[1].style.opacity='0';s[2].style.transform='translateY(-7px) rotate(-45deg)';}
  else{s[0].style.transform='';s[1].style.opacity='';s[2].style.transform='';}
});
document.querySelectorAll('.mob-l').forEach(function(a){a.addEventListener('click',function(){mob.classList.remove('open');var s=hamBtn.querySelectorAll('span');s[0].style.transform='';s[1].style.opacity='';s[2].style.transform='';});});

/* ── SCROLL REVEAL ───────────────────────────── */
var obs=new IntersectionObserver(function(entries){
  entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('in');});
},{threshold:0.08,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.sr,.sl,.sr2').forEach(function(el){obs.observe(el);});

/* ── SERVICES DRAG + ARROWS ──────────────────── */
var st=document.getElementById('svc-t');
var isD=false,sX,sL;
st.addEventListener('mousedown',function(e){isD=true;st.style.cursor='grabbing';sX=e.pageX-st.offsetLeft;sL=st.scrollLeft;});
['mouseleave','mouseup'].forEach(function(ev){st.addEventListener(ev,function(){isD=false;st.style.cursor='grab';});});
st.addEventListener('mousemove',function(e){if(!isD)return;e.preventDefault();st.scrollLeft=sL-(e.pageX-st.offsetLeft-sX);});
st.addEventListener('touchstart',function(e){sX=e.touches[0].pageX;sL=st.scrollLeft;},{passive:true});
st.addEventListener('touchmove',function(e){st.scrollLeft=sL-(e.touches[0].pageX-sX);},{passive:true});
document.getElementById('sp').addEventListener('click',function(){st.scrollBy({left:-300,behavior:'smooth'});});
document.getElementById('sn').addEventListener('click',function(){st.scrollBy({left:300,behavior:'smooth'});});

/* ── 3D SCROLL CARD ──────────────────────────── */
var scOuter=document.querySelector('.sc-outer'),scCard=document.getElementById('sc-card'),scHead=document.getElementById('sc-head');
function lerp(a,b,p){return a+(b-a)*p;}
function update3D(){
  if(!scOuter||!scCard)return;
  var rect=scOuter.getBoundingClientRect();
  var total=scOuter.offsetHeight-window.innerHeight;
  if(total<=0){scCard.style.transform='none';scCard.style.opacity='1';return;}
  var prog=Math.max(0,Math.min(1,-rect.top/total));
  scCard.style.transform='rotateX('+lerp(22,0,prog)+'deg) scale('+lerp(.84,1,prog)+') translateY('+lerp(60,0,prog)+'px)';
  scCard.style.opacity=String(Math.min(1,prog*1.9));
  scHead.style.transform='translateY('+lerp(0,-80,prog)+'px)';
  scHead.style.opacity=String(Math.max(0,1-prog*2.5));
}
window.addEventListener('load',update3D);

/* ── SECTORS ─────────────────────────────────── */
document.querySelectorAll('.s-tab').forEach(function(tab){
  tab.addEventListener('click',function(){
    document.querySelectorAll('.s-tab').forEach(function(t){t.classList.remove('active');});
    document.querySelectorAll('.s-panel').forEach(function(p){p.classList.remove('active');});
    tab.classList.add('active');
    var panel=document.getElementById('p-'+tab.dataset.p);
    if(panel)panel.classList.add('active');
  });
});

/* ── FORM SUBMIT ─────────────────────────────── */
window.submitForm=function(btn){
  btn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg> Enquiry Sent!';
  btn.style.background='#16a34a';btn.disabled=true;
  setTimeout(function(){
    btn.innerHTML='Send Enquiry <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
    btn.style.background='';btn.disabled=false;
  },3500);
};

})();
</script>
